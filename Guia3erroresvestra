<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Checklist Comercial — VESTRA</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap');

:root {
–negro: #0A0A0A;
–azul: #0057FF;
–azul-suave: #0a1428;
–azul-borde: #0d2150;
–blanco: #FFFFFF;
–gris: #888888;
–gris-claro: #F2F2F2;
–superficie: #111111;
–borde: #1e1e1e;
–verde: #00875A;
–verde-bg: #051a12;
–naranja: #B86800;
–naranja-bg: #1a1000;
–rojo: #C8392B;
–rojo-bg: #1a0804;
}

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–negro);
color: var(–blanco);
font-family: ‘DM Sans’, sans-serif;
min-height: 100vh;
padding: 0 20px 80px;
display: flex;
flex-direction: column;
align-items: center;
}

/* BARRA TOP */
.barra-top {
width: 100%;
background: var(–azul);
padding: 10px 20px;
text-align: center;
margin-bottom: 0;
}

.barra-top p {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: rgba(255,255,255,0.9);
letter-spacing: 1px;
}

.barra-top span { color: #FFD700; font-weight: 500; }

.container {
width: 100%;
max-width: 620px;
padding-top: 36px;
}

/* HEADER */
.header {
display: flex;
justify-content: space-between;
align-items: center;
margin-bottom: 40px;
}

.logo { display: flex; align-items: baseline; gap: 8px; }

.logo-uv {
font-family: ‘Syne’, sans-serif;
font-size: 26px;
font-weight: 800;
color: var(–azul);
letter-spacing: -1px;
}

.logo-nombre {
font-size: 11px;
color: var(–gris);
letter-spacing: 2px;
text-transform: uppercase;
}

.logo-badge {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–azul);
border: 1px solid var(–azul);
padding: 4px 10px;
letter-spacing: 1px;
text-transform: uppercase;
}

/* INTRO CARD */
.intro-card {
background: var(–superficie);
border: 1px solid var(–borde);
border-top: 4px solid var(–azul);
padding: 28px 24px;
margin-bottom: 12px;
}

.intro-tag {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–azul);
letter-spacing: 3px;
text-transform: uppercase;
margin-bottom: 14px;
}

.intro-card h1 {
font-family: ‘Syne’, sans-serif;
font-size: clamp(22px, 5vw, 32px);
font-weight: 800;
line-height: 1.15;
margin-bottom: 12px;
}

.intro-card h1 span { color: var(–azul); }

.intro-card .subtexto {
font-size: 14px;
color: var(–gris);
line-height: 1.7;
font-weight: 300;
margin-bottom: 18px;
}

.tag-gratis {
display: inline-flex;
align-items: center;
gap: 6px;
background: var(–azul-suave);
border: 1px solid var(–azul-borde);
color: var(–azul);
font-family: ‘DM Mono’, monospace;
font-size: 10px;
padding: 6px 14px;
letter-spacing: 1px;
text-transform: uppercase;
}

/* INSTRUCCIÓN */
.instruccion {
background: var(–azul-suave);
border: 1px solid var(–azul-borde);
border-left: 3px solid var(–azul);
padding: 14px 18px;
margin-bottom: 12px;
display: flex;
align-items: flex-start;
gap: 12px;
}

.instruccion .icono { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

.instruccion p {
font-size: 13px;
color: #aac0ff;
line-height: 1.6;
font-weight: 400;
}

.instruccion p span { color: var(–blanco); font-weight: 600; }

/* PROGRESO */
.progreso-card {
background: var(–superficie);
border: 1px solid var(–borde);
padding: 16px 20px;
margin-bottom: 16px;
}

.progreso-top {
display: flex;
justify-content: space-between;
align-items: center;
margin-bottom: 10px;
}

.progreso-top span {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–gris);
letter-spacing: 2px;
text-transform: uppercase;
}

.prog-count {
font-family: ‘DM Mono’, monospace;
font-size: 13px;
color: var(–azul) !important;
font-weight: 500;
}

.barra-track {
width: 100%;
height: 3px;
background: var(–borde);
}

.barra-fill {
height: 100%;
background: var(–azul);
transition: width 0.4s ease;
width: 0%;
}

/* ITEMS */
.seccion-titulo {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–gris);
letter-spacing: 3px;
text-transform: uppercase;
margin-bottom: 10px;
padding-left: 2px;
}

.items-lista {
display: flex;
flex-direction: column;
gap: 3px;
margin-bottom: 20px;
}

.item {
background: var(–superficie);
border: 1px solid var(–borde);
border-left: 3px solid transparent;
padding: 16px 18px;
display: flex;
align-items: flex-start;
gap: 14px;
cursor: pointer;
transition: all 0.2s;
user-select: none;
-webkit-tap-highlight-color: transparent;
}

.item:hover { border-left-color: #333; background: #131313; }

.item.marcado {
border-left-color: var(–azul);
background: var(–azul-suave);
}

.item.marcado .check-box {
background: var(–azul);
border-color: var(–azul);
}

.item.marcado .check-box::after {
opacity: 1;
transform: rotate(45deg) scale(1);
}

.item.marcado .item-texto { color: var(–blanco); font-weight: 500; }
.item.marcado .item-num { color: var(–azul); }

.check-box {
width: 22px;
height: 22px;
border: 1.5px solid #333;
flex-shrink: 0;
position: relative;
transition: all 0.2s;
margin-top: 1px;
}

.check-box::after {
content: ‘’;
position: absolute;
left: 5px;
top: 2px;
width: 6px;
height: 10px;
border-right: 2px solid var(–blanco);
border-bottom: 2px solid var(–blanco);
transform: rotate(45deg) scale(0);
opacity: 0;
transition: all 0.15s ease;
}

.item-body { flex: 1; }

.item-num {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: #333;
letter-spacing: 1.5px;
text-transform: uppercase;
margin-bottom: 4px;
transition: color 0.2s;
}

.item-texto {
font-size: 14px;
color: #aaaaaa;
line-height: 1.55;
font-weight: 400;
transition: all 0.2s;
}

/* BOTÓN */
.btn-diagnostico {
width: 100%;
background: var(–azul);
color: var(–blanco);
border: none;
padding: 18px;
font-family: ‘Syne’, sans-serif;
font-size: 14px;
font-weight: 700;
letter-spacing: 1px;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
opacity: 0.3;
pointer-events: none;
margin-bottom: 10px;
}

.btn-diagnostico.activo { opacity: 1; pointer-events: all; }
.btn-diagnostico.activo:hover { background: #0047d4; }

.btn-nota {
text-align: center;
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–gris);
letter-spacing: 1px;
margin-bottom: 32px;
}

/* RESULTADO */
.resultado {
display: none;
flex-direction: column;
gap: 3px;
animation: subir 0.4s ease;
}

.resultado.visible { display: flex; }

@keyframes subir {
from { opacity: 0; transform: translateY(20px); }
to   { opacity: 1; transform: translateY(0); }
}

/* PUNTUACIÓN */
.punt-card {
padding: 28px 24px;
border: 1px solid var(–borde);
text-align: center;
}

.punt-emoji { font-size: 44px; margin-bottom: 12px; display: block; }

.punt-num {
font-family: ‘Syne’, sans-serif;
font-size: clamp(56px, 12vw, 80px);
font-weight: 800;
line-height: 1;
margin-bottom: 4px;
}

.punt-de {
font-size: 13px;
color: var(–gris);
margin-bottom: 14px;
font-weight: 300;
}

.punt-badge {
display: inline-block;
font-family: ‘DM Mono’, monospace;
font-size: 11px;
padding: 6px 18px;
letter-spacing: 1px;
text-transform: uppercase;
}

.nivel-verde { background: var(–verde-bg); border-top: 4px solid var(–verde); }
.nivel-verde .punt-num { color: var(–verde); }
.nivel-verde .punt-badge { background: var(–verde-bg); color: var(–verde); border: 1px solid var(–verde); }

.nivel-naranja { background: var(–naranja-bg); border-top: 4px solid var(–naranja); }
.nivel-naranja .punt-num { color: var(–naranja); }
.nivel-naranja .punt-badge { background: var(–naranja-bg); color: var(–naranja); border: 1px solid var(–naranja); }

.nivel-rojo { background: var(–rojo-bg); border-top: 4px solid var(–rojo); }
.nivel-rojo .punt-num { color: var(–rojo); }
.nivel-rojo .punt-badge { background: var(–rojo-bg); color: var(–rojo); border: 1px solid var(–rojo); }

/* MENSAJE PERSONAL */
.mensaje-card {
background: var(–superficie);
border: 1px solid var(–borde);
border-left: 4px solid var(–azul);
padding: 22px 24px;
}

.mensaje-header {
display: flex;
align-items: center;
gap: 12px;
margin-bottom: 16px;
}

.msg-avatar {
width: 40px;
height: 40px;
background: var(–azul);
display: flex;
align-items: center;
justify-content: center;
font-family: ‘Syne’, sans-serif;
font-size: 13px;
font-weight: 800;
color: var(–blanco);
flex-shrink: 0;
}

.msg-autor strong {
display: block;
font-family: ‘Syne’, sans-serif;
font-size: 13px;
font-weight: 700;
color: var(–blanco);
}

.msg-autor span {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–gris);
letter-spacing: 1px;
}

.mensaje-texto {
font-size: 14px;
color: #cccccc;
line-height: 1.8;
font-weight: 300;
}

.mensaje-texto strong { color: var(–blanco); font-weight: 600; }
.mensaje-texto em { color: var(–azul); font-style: normal; font-weight: 600; }

/* LO QUE MARCASTE */
.marcadas-card {
background: var(–superficie);
border: 1px solid var(–borde);
padding: 22px 24px;
}

.marcadas-titulo {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–gris);
letter-spacing: 3px;
text-transform: uppercase;
margin-bottom: 14px;
}

.marcadas-lista { display: flex; flex-direction: column; gap: 8px; }

.marcada-item {
display: flex;
align-items: flex-start;
gap: 10px;
background: var(–azul-suave);
border: 1px solid var(–azul-borde);
padding: 10px 14px;
}

.marcada-dot {
width: 6px;
height: 6px;
background: var(–azul);
border-radius: 50%;
flex-shrink: 0;
margin-top: 5px;
}

.marcada-texto {
font-size: 13px;
color: #aac0ff;
line-height: 1.5;
font-weight: 400;
}

/* PASOS */
.pasos-card {
background: var(–superficie);
border: 1px solid var(–borde);
padding: 22px 24px;
}

.pasos-titulo {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–gris);
letter-spacing: 3px;
text-transform: uppercase;
margin-bottom: 18px;
}

.paso-item {
display: flex;
gap: 14px;
margin-bottom: 16px;
align-items: flex-start;
}

.paso-item:last-child { margin-bottom: 0; }

.paso-num {
width: 28px;
height: 28px;
background: var(–azul);
display: flex;
align-items: center;
justify-content: center;
font-family: ‘Syne’, sans-serif;
font-size: 13px;
font-weight: 800;
color: var(–blanco);
flex-shrink: 0;
}

.paso-contenido strong {
display: block;
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
font-weight: 600;
color: var(–blanco);
margin-bottom: 2px;
}

.paso-contenido span {
font-size: 13px;
color: var(–gris);
line-height: 1.5;
font-weight: 300;
}

/* CTA */
.cta-card {
background: var(–azul);
padding: 30px 24px;
text-align: center;
}

.cta-emoji { font-size: 36px; margin-bottom: 12px; display: block; }

.cta-titulo {
font-family: ‘Syne’, sans-serif;
font-size: 20px;
font-weight: 800;
color: var(–blanco);
line-height: 1.25;
margin-bottom: 8px;
white-space: pre-line;
}

.cta-sub {
font-size: 13px;
color: rgba(255,255,255,0.7);
line-height: 1.65;
margin-bottom: 20px;
font-weight: 300;
}

.cta-beneficios {
display: flex;
flex-direction: column;
gap: 6px;
margin-bottom: 22px;
text-align: left;
}

.cta-beneficio {
font-size: 13px;
color: rgba(255,255,255,0.85);
font-weight: 500;
display: flex;
align-items: center;
gap: 8px;
}

.cta-btn {
display: block;
width: 100%;
background: var(–blanco);
color: var(–azul);
padding: 16px;
font-family: ‘Syne’, sans-serif;
font-size: 14px;
font-weight: 800;
letter-spacing: 1px;
text-transform: uppercase;
text-decoration: none;
border: none;
cursor: pointer;
margin-bottom: 10px;
transition: opacity 0.2s;
}

.cta-btn:hover { opacity: 0.9; }

.cta-nota {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: rgba(255,255,255,0.4);
letter-spacing: 1px;
}

/* REINICIAR */
.btn-reiniciar {
width: 100%;
background: none;
border: 1px solid var(–borde);
color: var(–gris);
padding: 14px;
font-family: ‘DM Mono’, monospace;
font-size: 11px;
letter-spacing: 2px;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
}

.btn-reiniciar:hover { border-color: #444; color: var(–blanco); }

/* FOOTER */
.footer {
margin-top: 48px;
text-align: center;
}

.footer p {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: #222;
letter-spacing: 2px;
text-transform: uppercase;
line-height: 1.8;
}

.footer a { color: var(–azul); text-decoration: none; }
.footer span { color: var(–azul); }
</style>

</head>
